            "src": {
              "choice": "value",
              "value": "00:00:00:00:00:01"
            }
          }
        },
        {
          "choice": "ipv4",
          "ipv4": {
            "src": {
              "choice": "value",
              "value": "192.168.1.1"
            },
            "dst": {
              "choice": "value",
              "value": "192.168.2.1"
            }
          }
        }
      ],
      "size": {
        "choice": "fixed",
        "fixed": 1500
      },
      "rate": {
        "choice": "percentage",
        "percentage": 100
      },
      "duration": {
        "choice": "continuous"
